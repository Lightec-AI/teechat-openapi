{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://teechat.ai/schemas/openapi/sealed-tls-key.v1.json",
  "title": "SealedTlsKeyBlob",
  "type": "object",
  "required": ["seal_version", "measurement", "nonce_b64", "ciphertext_b64"],
  "properties": {
    "seal_version": {
      "type": "integer",
      "enum": [1, 2],
      "description": "1 = HKDF measurement-labeled (CVM MVP); 2 = SGX EGETKEY (Fortanix SealData)"
    },
    "measurement": {
      "oneOf": [
        {
          "type": "object",
          "required": ["kind", "value"],
          "properties": {
            "kind": { "const": "mrenclave" },
            "value": { "type": "string", "minLength": 1 }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["kind", "launch_digest", "image_digest"],
          "properties": {
            "kind": { "const": "launch_digest" },
            "launch_digest": { "type": "string", "minLength": 1 },
            "image_digest": { "type": "string", "minLength": 1 }
          },
          "additionalProperties": false
        }
      ]
    },
    "nonce_b64": { "type": "string" },
    "ciphertext_b64": { "type": "string" },
    "seal_data_b64": {
      "type": "string",
      "description": "URL-safe base64 Fortanix SealData JSON; required when seal_version is 2"
    }
  },
  "additionalProperties": false,
  "allOf": [
    {
      "if": { "properties": { "seal_version": { "const": 2 } } },
      "then": { "required": ["seal_data_b64"] }
    }
  ]
}
