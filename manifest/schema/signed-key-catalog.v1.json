{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://teechat.ai/schemas/openapi/signed-key-catalog.v1.json",
  "title": "SignedKeyCatalog",
  "type": "object",
  "required": ["catalog_version", "issued_at_ms", "keys", "signature_hex"],
  "properties": {
    "catalog_version": { "type": "integer", "minimum": 1 },
    "issued_at_ms": { "type": "integer", "minimum": 0 },
    "keys": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["key_id", "key_hash_hex"],
        "properties": {
          "key_id": { "type": "string", "minLength": 1 },
          "key_hash_hex": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "revoked": { "type": "boolean", "default": false }
        },
        "additionalProperties": false
      }
    },
    "signature_hex": { "type": "string", "pattern": "^[0-9a-f]+$" }
  },
  "additionalProperties": false
}
